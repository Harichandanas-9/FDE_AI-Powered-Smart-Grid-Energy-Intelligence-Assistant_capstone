# ===== Smart Grid AI Assistant — Backend environment template =====
# Copy this file to .env and fill in your keys. NEVER commit the real .env.

# --- App ---
APP_NAME="Smart Grid AI Assistant"
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Paths (relative to backend/ when uvicorn runs from backend/) ---
DATA_DIR=./datasets
CHROMA_PERSIST_DIR=../chroma_store

# --- Embeddings ---
# Auto fallback chain (no manual switching needed):
#   sentence-transformers → fastembed (ONNX) → HashEmbedder (pure NumPy)
# If torch/DLL fails, fastembed takes over. If that also fails, HashEmbedder
# ensures the app never crashes. Leave as-is for best quality.
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FASTEMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Chunking ---
# strategy: sentence | fixed | incident
#   sentence = split on sentence boundaries (window=CHUNK_SIZE, overlap=CHUNK_OVERLAP)
#   fixed    = fixed character window with stride overlap
#   incident = one chunk per incident row (fastest, no splitting)
# Invalid value auto-falls back to "sentence" — safe to change.
CHUNK_STRATEGY=sentence
CHUNK_SIZE=4
CHUNK_OVERLAP=1

# --- Reranker ---
# Safe to keep RERANKER_ENABLED=true — fallback chain is automatic:
#   CrossEncoder (ms-marco-MiniLM-L-6-v2) → ScoreFusion (no model needed)
# ScoreFusion uses normalized semantic + BM25 scores when CrossEncoder fails.
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# --- LLM Provider ---
# Fallback chain: groq_large → template (offline, no key needed)
# With a valid GROQ_API_KEY the real LLM is used.
# Without any key the template provider generates structured answers — demo works fully.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_LARGE=llama-3.3-70b-versatile
GROQ_MODEL_SMALL=llama-3.1-8b-instant
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LLM_FALLBACK_CHAIN=groq_large

# --- Retrieval ---
RETRIEVAL_TOP_K=20
FINAL_TOP_K=5
RRF_SEMANTIC_WEIGHT=0.6
RRF_KEYWORD_WEIGHT=0.4

# CRAG: query reformulation when top score < threshold. 0.0 = disabled.
CRAG_RELEVANCE_THRESHOLD=0.0

# --- Semantic cache ---
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ITEMS=500

# --- Multi-tenancy + JWT (off by default for demo) ---
MULTI_TENANCY_ENABLED=false
JWT_SECRET=change-me-in-production-min-32-chars-long
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=480
DEMO_USERS={"admin":{"password":"admin","tenant_id":"default","role":"admin"},"acme":{"password":"acme123","tenant_id":"acme","role":"engineer"}}

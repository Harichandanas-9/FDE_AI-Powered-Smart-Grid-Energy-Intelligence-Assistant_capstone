# ===== Smart Grid AI Assistant — Backend environment template =====
# Copy to .env and fill in. NEVER commit the real .env.

# --- App ---
APP_NAME="Smart Grid AI Assistant"
APP_ENV=development            # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO

# --- CORS ---
# Comma-separated list of allowed origins for the frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Paths ---
DATA_DIR=./datasets
CHROMA_PERSIST_DIR=./chroma_store

# --- Embeddings / Models ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# --- LLM Provider (pick one; leave others blank) ---
# Primary provider is Groq (fast, free tier). Leave keys empty to use the
# offline deterministic template provider (demo still works with no keys).
LLM_PROVIDER=groq            # openai | anthropic | ollama
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Retrieval ---
RETRIEVAL_TOP_K=20
FINAL_TOP_K=5
RRF_SEMANTIC_WEIGHT=0.6
RRF_KEYWORD_WEIGHT=0.4
